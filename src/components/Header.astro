---
import { u } from '../lib/url';

const nav = [
  { label: 'Über MHN', href: u('/ueber-mhn') },
  { label: 'Mitgliedschaft', href: u('/aufnahme') },
  { label: 'Mind-Akademie', href: u('/akademie') },
  { label: 'Veranstaltungen', href: u('/veranstaltungen') },
  { label: 'Kontakt', href: u('/kontakt') },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={u('/')} class="flex items-center gap-2 group">
        <div class="w-9 h-9 rounded-xl bg-[#1e3a5f] flex items-center justify-center text-white font-bold text-lg group-hover:bg-[#2d5a9e] transition-colors">
          M
        </div>
        <span class="font-bold text-[#1e3a5f] text-lg hidden sm:block">
          Mind-Hochschul-Netzwerk
        </span>
        <span class="font-bold text-[#1e3a5f] text-lg sm:hidden">MHN</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {nav.map((item) => (
          <a
            href={item.href}
            class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-[#1e3a5f] hover:bg-blue-50 transition-all"
          >
            {item.label}
          </a>
        ))}
        <a
          href={u('/aufnahme')}
          class="ml-3 px-4 py-2 rounded-lg bg-[#e85d26] text-white text-sm font-semibold hover:bg-[#f47a4a] transition-colors"
        >
          Mitglied werden
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors"
        aria-label="Menü öffnen"
        aria-expanded="false"
      >
        <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white px-4 pb-4">
    <nav class="flex flex-col gap-1 pt-3">
      {nav.map((item) => (
        <a
          href={item.href}
          class="px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 hover:text-[#1e3a5f] hover:bg-blue-50 transition-all"
        >
          {item.label}
        </a>
      ))}
      <a
        href={u('/aufnahme')}
        class="mt-2 px-4 py-2.5 rounded-lg bg-[#e85d26] text-white text-sm font-semibold text-center hover:bg-[#f47a4a] transition-colors"
      >
        Mitglied werden
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
