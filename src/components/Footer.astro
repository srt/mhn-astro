---
import { u } from '../lib/url';
---

<footer class="bg-[#1e3a5f] text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 rounded-xl bg-white/10 flex items-center justify-center text-white font-bold text-lg">
            M
          </div>
          <span class="font-bold text-lg">Mind-Hochschul-Netzwerk</span>
        </div>
        <p class="text-blue-200 text-sm leading-relaxed max-w-xs">
          Eine Gemeinschaft neugieriger und engagierter Menschen aller Altersgruppen, die sich dem lebenslangen Lernen verschrieben haben.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-blue-300 mb-3">Navigation</h3>
        <ul class="space-y-2 text-sm text-blue-200">
          <li><a href={u('/')} class="hover:text-white transition-colors">Startseite</a></li>
          <li><a href={u('/ueber-mhn')} class="hover:text-white transition-colors">Über MHN</a></li>
          <li><a href={u('/aufnahme')} class="hover:text-white transition-colors">Mitgliedschaft</a></li>
          <li><a href={u('/akademie')} class="hover:text-white transition-colors">Mind-Akademie</a></li>
          <li><a href={u('/veranstaltungen')} class="hover:text-white transition-colors">Veranstaltungen</a></li>
          <li><a href={u('/kontakt')} class="hover:text-white transition-colors">Kontakt</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-blue-300 mb-3">Rechtliches</h3>
        <ul class="space-y-2 text-sm text-blue-200">
          <li><a href={u('/impressum')} class="hover:text-white transition-colors">Impressum</a></li>
          <li><a href={u('/datenschutz')} class="hover:text-white transition-colors">Datenschutz</a></li>
          <li>
            <a
              href="https://wiki.mind-hochschul-netzwerk.de/s/327084de-2f86-43bc-8a5f-045a1283b55a"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white transition-colors"
            >
              Satzung
            </a>
          </li>
          <li><a href="https://www.mind-hochschul-netzwerk.de/portal" class="hover:text-white transition-colors">Mitgliederportal</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-blue-300">
      <p>© {new Date().getFullYear()} Mind-Hochschul-Netzwerk e.V.</p>
      <p>Gegründet 2001 · Unabhängig seit 2022</p>
    </div>
  </div>
</footer>
