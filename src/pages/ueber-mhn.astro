---
import Layout from '../layouts/Layout.astro';

const timeline = [
  { year: '2001', event: 'Gründung als Mensa-Projekt unter dem Namen "Mind-Hochschul-Netzwerk"' },
  { year: '2002', event: 'Erste Mind-Akademie findet statt – der Grundstein für die jährliche Hauptveranstaltung' },
  { year: '2018', event: 'Mitgliedervotum für die Unabhängigkeit von der Mensa Deutschland' },
  { year: '2022', event: 'MHN wird vollständig unabhängiger Verein' },
  { year: 'Heute', event: 'Über 250 Mitglieder, 23 Akademien und eine lebendige, wachsende Gemeinschaft' },
];

const principles = [
  {
    icon: '🤝',
    title: 'Engagement zahlt sich aus',
    desc: 'Wer aktiv mitmacht, erhält Mitgestaltungsrechte. Beteiligung wird nicht nur erwartet, sondern belohnt.',
  },
  {
    icon: '💬',
    title: 'Klare Kommunikation',
    desc: 'Wir sagen klar, was wir tun können und was nicht. Verlässlichkeit ist uns wichtiger als Gefälligkeit.',
  },
  {
    icon: '🧠',
    title: 'Persönlicher Austausch',
    desc: 'Konflikte lösen wir persönlich – nie per E-Mail oder Messenger. Das schafft Vertrauen.',
  },
  {
    icon: '✅',
    title: 'Respekt vor Grenzen',
    desc: 'Absagen werden ohne Druck und Nachfragen akzeptiert. Jeder entscheidet selbst, was er leisten kann.',
  },
  {
    icon: '🔨',
    title: 'Konstruktive Kritik',
    desc: 'Kritik ist immer mit dem Angebot verbunden, selbst mitzuhelfen. Meckern ohne Handeln gilt nicht.',
  },
  {
    icon: '🚀',
    title: 'Pragmatismus',
    desc: 'Wir handeln lieber schnell und unvollkommen als langsam und perfekt. Anfangen ist besser als abwarten.',
  },
];
---

<Layout
  title="Über MHN – Mind-Hochschul-Netzwerk"
  description="Erfahre mehr über das Mind-Hochschul-Netzwerk: unsere Geschichte, Mission und Grundsätze."
>
  <!-- Page header -->
  <section class="pt-32 pb-16 bg-gradient-to-b from-[#1e3a5f] to-[#2d5a9e] text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-blue-200 text-sm font-medium mb-4">
        Über uns
      </span>
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-4">Das Mind-Hochschul-Netzwerk</h1>
      <p class="text-xl text-blue-100 leading-relaxed max-w-2xl mx-auto">
        Wir sind eine Gemeinschaft neugieriger und engagierter Menschen aller Altersgruppen, die sich dem lebenslangen Lernen verschrieben haben.
      </p>
    </div>
  </section>

  <!-- What we are -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-[#1e3a5f] mb-6">Was ist das MHN?</h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>
              Das Mind-Hochschul-Netzwerk (MHN) verbindet aufgeschlossene junge Menschen über Fächergrenzen hinweg. Bei uns trifft Naturwissenschaft auf Geisteswissenschaft, Wirtschaft auf Kunst, Technik auf Philosophie.
            </p>
            <p>
              Mitglieder teilen ihr Wissen in Workshops und Seminaren, treffen sich in regionalen Gruppen und kommen jährlich zur großen Mind-Akademie zusammen. Das Besondere: Alles wird von Mitgliedern für Mitglieder organisiert.
            </p>
            <p>
              Das „M" in unserem Namen steht für mehr als nur den Anfangsbuchstaben – es steht für Mitmachen. Wer sich einbringt, gestaltet mit.
            </p>
          </div>
        </div>
        <div class="bg-gray-50 rounded-2xl p-8">
          <h3 class="font-bold text-[#1e3a5f] text-xl mb-6">Was das MHN bietet</h3>
          <ul class="space-y-4">
            {[
              'Vernetzung mit kreativen, engagierten Gleichgesinnten',
              'Regionale Gruppentreffen in Hochschulstädten',
              'Akademische Workshops und Seminare zu diversen Themen',
              'Die Mind-Akademie: jährliche Hauptveranstaltung im Oktober',
              'Das MHN-Camp: sommerliche Alternative in entspannter Atmosphäre',
              'Unconferences: selbstorganisierte offene Formate',
            ].map((item) => (
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-[#e85d26] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span class="text-gray-700 text-sm">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="text-[#e85d26] font-semibold text-sm uppercase tracking-wider">Wie wir arbeiten</span>
        <h2 class="mt-2 text-3xl font-bold text-[#1e3a5f]">Unsere sechs Grundsätze</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {principles.map((p) => (
          <div class="bg-white rounded-2xl p-6 border border-gray-100 hover:shadow-md transition-shadow">
            <div class="text-3xl mb-3">{p.icon}</div>
            <h3 class="font-bold text-[#1e3a5f] mb-2">{p.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="text-[#e85d26] font-semibold text-sm uppercase tracking-wider">Unsere Geschichte</span>
        <h2 class="mt-2 text-3xl font-bold text-[#1e3a5f]">Meilensteine</h2>
      </div>
      <div class="relative">
        <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-gray-200"></div>
        <div class="space-y-8">
          {timeline.map((item) => (
            <div class="flex gap-6 relative">
              <div class="w-16 shrink-0 flex items-start justify-center">
                <div class="w-4 h-4 rounded-full bg-[#e85d26] mt-1 ring-4 ring-white z-10 relative"></div>
              </div>
              <div class="pb-2">
                <span class="text-[#e85d26] font-bold text-lg">{item.year}</span>
                <p class="text-gray-700 mt-1 text-sm leading-relaxed">{item.event}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-[#1e3a5f] text-white text-center">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4">Werde Teil unserer Geschichte</h2>
      <p class="text-blue-200 mb-6">Bewirb dich jetzt und gestalte das MHN aktiv mit.</p>
      <a
        href="/aufnahme"
        class="inline-block px-8 py-4 rounded-xl bg-[#e85d26] text-white font-semibold text-lg hover:bg-[#f47a4a] transition-colors"
      >
        Jetzt bewerben
      </a>
    </div>
  </section>
</Layout>
