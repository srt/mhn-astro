---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Kontakt – MHN"
  description="Nimm Kontakt mit dem Mind-Hochschul-Netzwerk auf."
>
  <!-- Header -->
  <section class="pt-32 pb-16 bg-gradient-to-b from-[#1e3a5f] to-[#2d5a9e] text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-blue-200 text-sm font-medium mb-4">
        Kontakt
      </span>
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-4">Schreib uns</h1>
      <p class="text-xl text-blue-100 leading-relaxed max-w-2xl mx-auto">
        Hast du Fragen zum MHN, zur Mitgliedschaft oder zu unseren Veranstaltungen? Wir freuen uns von dir zu hören.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact form -->
        <div>
          <h2 class="text-2xl font-bold text-[#1e3a5f] mb-6">Nachricht senden</h2>
          <form class="space-y-5">
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="first-name">Vorname</label>
                <input
                  id="first-name"
                  type="text"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#1e3a5f] focus:border-transparent text-sm"
                  placeholder="Max"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="last-name">Nachname</label>
                <input
                  id="last-name"
                  type="text"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#1e3a5f] focus:border-transparent text-sm"
                  placeholder="Mustermann"
                />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="email">E-Mail-Adresse</label>
              <input
                id="email"
                type="email"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#1e3a5f] focus:border-transparent text-sm"
                placeholder="max@beispiel.de"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="subject">Betreff</label>
              <select
                id="subject"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#1e3a5f] focus:border-transparent text-sm text-gray-700"
              >
                <option value="">Bitte wählen...</option>
                <option>Mitgliedschaft & Aufnahme</option>
                <option>Mind-Akademie</option>
                <option>Veranstaltungen</option>
                <option>Regionale Gruppen</option>
                <option>Sonstiges</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="message">Nachricht</label>
              <textarea
                id="message"
                rows="5"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#1e3a5f] focus:border-transparent text-sm resize-none"
                placeholder="Deine Nachricht..."
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full px-6 py-3.5 rounded-xl bg-[#e85d26] text-white font-semibold hover:bg-[#f47a4a] transition-colors"
            >
              Nachricht senden
            </button>
          </form>
        </div>

        <!-- Info -->
        <div class="space-y-6">
          <div>
            <h2 class="text-2xl font-bold text-[#1e3a5f] mb-6">Weitere Wege zu uns</h2>
            <div class="space-y-4">
              {[
                {
                  icon: '🌐',
                  title: 'Mitgliederportal',
                  desc: 'Bestehende Mitglieder nutzen das Portal für alle internen Angelegenheiten.',
                  link: 'https://www.mind-hochschul-netzwerk.de/portal',
                  linkLabel: 'Zum Portal',
                },
                {
                  icon: '📋',
                  title: 'Wiki',
                  desc: 'Unser internes Wiki enthält Informationen, Dokumentation und Ressourcen.',
                  link: 'https://wiki.mind-hochschul-netzwerk.de',
                  linkLabel: 'Zum Wiki',
                },
                {
                  icon: '📬',
                  title: 'Diskussionslisten',
                  desc: 'Mitglieder tauschen sich über thematische E-Mail-Listen aus.',
                  link: 'https://www.mind-hochschul-netzwerk.de/listen',
                  linkLabel: 'Zu den Listen',
                },
              ].map((item) => (
                <div class="flex gap-4 p-4 rounded-xl bg-gray-50">
                  <span class="text-2xl shrink-0">{item.icon}</span>
                  <div>
                    <h3 class="font-semibold text-[#1e3a5f]">{item.title}</h3>
                    <p class="text-gray-600 text-sm mt-0.5">{item.desc}</p>
                    <a
                      href={item.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-[#e85d26] text-sm font-semibold hover:underline mt-1 inline-block"
                    >
                      {item.linkLabel} →
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-blue-50 rounded-2xl p-6">
            <h3 class="font-bold text-[#1e3a5f] mb-2">Impressum & Datenschutz</h3>
            <p class="text-gray-600 text-sm mb-3">
              Alle rechtlichen Informationen findest du auf unseren entsprechenden Seiten.
            </p>
            <div class="flex gap-3 text-sm">
              <a href="/impressum" class="text-[#e85d26] font-semibold hover:underline">Impressum</a>
              <span class="text-gray-300">·</span>
              <a href="/datenschutz" class="text-[#e85d26] font-semibold hover:underline">Datenschutz</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
